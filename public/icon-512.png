<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" rx="128" fill="#3d7a4a"/>
  
  <!-- Leaf design -->
  <g transform="translate(256, 256)">
    <!-- Main leaf -->
    <ellipse cx="0" cy="20" rx="90" ry="140" fill="#7cb342" transform="rotate(-20)"/>
    <ellipse cx="0" cy="20" rx="80" ry="130" fill="#9ccc65" transform="rotate(-20)"/>
    
    <!-- Leaf vein -->
    <line x1="0" y1="-100" x2="0" y2="140" stroke="#7cb342" stroke-width="6" transform="rotate(-20)"/>
    
    <!-- Secondary leaf -->
    <ellipse cx="-40" cy="-10" rx="60" ry="100" fill="#8bc34a" transform="rotate(30)"/>
    <ellipse cx="-40" cy="-10" rx="50" ry="90" fill="#aed581" transform="rotate(30)"/>
    
    <!-- Stem -->
    <rect x="-8" y="100" width="16" height="80" rx="8" fill="#6d4c41"/>
    
    <!-- Small sprout -->
    <circle cx="50" cy="60" r="25" fill="#c5e1a5"/>
    <circle cx="50" cy="60" r="18" fill="#dcedc8"/>
  </g>
</svg>
